        <ui:Vector2IntField label="그리드 크기" name="GridSize" binding-path="gridSize" style="-unity-font-definition: url(&quot;project://database/Assets/Font/SCDream4.otf?fileID=12800000&amp;guid=3b4b0c251e5aa8f4cb40d36f1dc12f84&amp;type=3#SCDream4&quot;); font-size: 13px; margin-bottom: 3px;"/>
        <uie:ObjectField label="셀 오브젝트" type="UnityEngine.GameObject, UnityEngine.CoreModule" binding-path="cellPrefab" name="CellPrefab" style="-unity-font-definition: url(&quot;project://database/Assets/Font/SCDream4.otf?fileID=12800000&amp;guid=3b4b0c251e5aa8f4cb40d36f1dc12f84&amp;type=3#SCDream4&quot;); font-size: 13px; margin-bottom: 3px;"/>
